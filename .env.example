# ── Aero One Projekttool — environment variables ──
# Copy to .env.local for local dev; set the same keys in the Vercel project settings.
# Each value is created by you at the step noted; Claude wires the code around them.

# Step 1 — Neon Postgres (pooled connection string)
DATABASE_URL=

# Step 2 — Session signing secret. Generate: openssl rand -base64 48
SESSION_SECRET=

# Step 2/3 — Google OAuth web client (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Step 2 — Access allowlist: comma-separated emails and/or @domain entries
ALLOWED_EMAILS=@aero-one.de

# Step 3 — Encryption key for stored Google refresh tokens. Generate: openssl rand -base64 32
TOKEN_ENC_KEY=

# Step 4 — Brevo transactional email + SMS
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Aero One
BREVO_SMS_SENDER=AeroOne

# Step 4 — Shared secret guarding the cron endpoint
CRON_SECRET=
